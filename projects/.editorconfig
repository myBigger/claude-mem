# PrisonSIS EditorConfig
# https://editorconfig.org

root = true

# 所有文件
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Markdown 文件
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# YAML 文件
[*.{yml,yaml}]
indent_size = 2

# JSON 文件
[*.{json,jsonc}]
indent_size = 2

# CMake 文件
[CMakeLists.txt]
indent_size = 4

# C++ 头文件和源文件
[*.{cpp,h,hpp,cxx,hxx}]
indent_size = 4
max_line_length = 120

# Qt 项目特定
[*.{ui,qrc}]
indent_size = 4

# Python 文件
[*.py]
indent_size = 4

# Shell 脚本
[*.sh]
indent_size = 4
end_of_line = lf

# Windows 批处理文件
[*.bat]
end_of_line = crlf

# Makefile
[Makefile]
indent_style = tab

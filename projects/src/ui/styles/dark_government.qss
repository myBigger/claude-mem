/* ============================================================
   PrisonSIS — Government Blue Dark Design System
   Design tokens: see DESIGN_SYSTEM.md for full documentation
   ============================================================ */

/* ── Global Base ─────────────────────────────────────────── */
QWidget {
    background: #0A0E14;
    color: #E6EDF3;
    font-family: 'Inter', 'SF Pro', 'Segoe UI', 'Noto Sans CJK SC', 'Microsoft YaHei', sans-serif;
    font-size: 13px;
}

/* ── Window / Dialog ─────────────────────────────────────── */
QMainWindow {
    background: #0A0E14;
}
QDialog {
    background: #0A0E14;
}

/* ── Labels ───────────────────────────────────────────────── */
QLabel {
    color: #E6EDF3;
    background: transparent;
}

/* ── Buttons: General ────────────────────────────────────── */
QPushButton {
    background: #1C2128;
    color: #E6EDF3;
    border: 1px solid #21262D;
    border-radius: 4px;
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 500;
    font-family: 'Inter', 'SF Pro', 'Segoe UI', 'Noto Sans CJK SC', 'Microsoft YaHei', sans-serif;
    min-height: 18px;
}
QPushButton:hover {
    background: #30363D;
    border-color: #30363D;
    color: #FFFFFF;
}
QPushButton:pressed {
    background: #161B22;
    border-color: #21262D;
}
QPushButton:disabled {
    background: #161B22;
    color: #6E7681;
    border-color: #21262D;
}

/* ── Buttons: Primary (Brand / Government Blue) ───────────── */
QPushButton#primaryBtn,
QPushButton[objectName="primaryBtn"] {
    background: #0066CC;
    color: #FFFFFF;
    border: none;
    border-radius: 4px;
    font-weight: 600;
    font-size: 13px;
    padding: 6px 14px;
}
QPushButton#primaryBtn:hover,
QPushButton[objectName="primaryBtn"]:hover {
    background: #0052A3;
    color: #FFFFFF;
}
QPushButton#primaryBtn:pressed,
QPushButton[objectName="primaryBtn"]:pressed {
    background: #003D82;
}
QPushButton#primaryBtn:disabled,
QPushButton[objectName="primaryBtn"]:disabled {
    background: #161B22;
    color: #6E7681;
}

/* ── Buttons: Danger ──────────────────────────────────────── */
QPushButton#dangerBtn {
    background: #E53E3E;
    color: #FFFFFF;
    border: none;
    border-radius: 4px;
    font-weight: 600;
    font-size: 13px;
    padding: 6px 14px;
}
QPushButton#dangerBtn:hover { background: #C53030; }
QPushButton#dangerBtn:pressed { background: #9B2C2C; }
QPushButton#dangerBtn:disabled {
    background: #161B22;
    color: #6E7681;
}

/* ── Buttons: Success ─────────────────────────────────────── */
QPushButton#successBtn {
    background: #22C55E;
    color: #FFFFFF;
    border: none;
    border-radius: 4px;
    font-weight: 600;
    font-size: 13px;
    padding: 6px 14px;
}
QPushButton#successBtn:hover { background: #16A34A; }
QPushButton#successBtn:disabled {
    background: #161B22;
    color: #6E7681;
}

/* ── Buttons: Icon-only ───────────────────────────────────── */
QPushButton[objectName="iconBtn"] {
    min-width: 32px;
    min-height: 32px;
    padding: 4px 6px;
}

/* ── Inputs: LineEdit ─────────────────────────────────────── */
QLineEdit {
    background: #0F1419;
    color: #E6EDF3;
    border: 1px solid #21262D;
    border-radius: 4px;
    padding: 7px 10px;
    font-size: 13px;
    font-family: 'Inter', 'SF Pro', 'Segoe UI', 'Noto Sans CJK SC', 'Microsoft YaHei', sans-serif;
    selection-background-color: #0066CC;
}
QLineEdit:focus {
    border-color: #0066CC;
    background: #161B22;
}
QLineEdit:disabled {
    background: #0A0E14;
    color: #6E7681;
    border-color: #161B22;
}
QLineEdit::placeholder {
    color: #484F58;
}

/* ── Inputs: TextEdit / PlainTextEdit ────────────────────── */
QTextEdit, QPlainTextEdit {
    background: #0F1419;
    color: #E6EDF3;
    border: 1px solid #21262D;
    border-radius: 4px;
    padding: 7px 10px;
    font-size: 13px;
    font-family: 'Inter', 'SF Pro', 'Segoe UI', 'Noto Sans CJK SC', 'Microsoft YaHei', sans-serif;
    selection-background-color: #0066CC;
}
QTextEdit:focus, QPlainTextEdit:focus {
    border-color: #0066CC;
    background: #161B22;
}
QTextEdit:disabled, QPlainTextEdit:disabled {
    background: #0A0E14;
    color: #6E7681;
}

/* ── ComboBox ─────────────────────────────────────────────── */
QComboBox {
    background: #0F1419;
    color: #E6EDF3;
    border: 1px solid #21262D;
    border-radius: 4px;
    padding: 7px 10px;
    font-size: 13px;
    font-family: 'Inter', 'SF Pro', 'Segoe UI', 'Noto Sans CJK SC', 'Microsoft YaHei', sans-serif;
}
QComboBox:hover { border-color: #30363D; }
QComboBox:focus { border-color: #0066CC; }
QComboBox:disabled { background: #0A0E14; color: #6E7681; }
QComboBox::drop-down {
    border: none;
    width: 20px;
}
QComboBox QAbstractItemView {
    background: #161B22;
    color: #E6EDF3;
    border: 1px solid #21262D;
    border-radius: 4px;
    selection-background-color: #1C2128;
    padding: 4px;
}
QComboBox::item:checked {
    background-color: #0066CC33;
}

/* ── Tables ───────────────────────────────────────────────── */
QTableWidget, QTreeWidget {
    background: #0A0E14;
    alternate-background-color: #0F1419;
    color: #E6EDF3;
    gridline-color: #21262D;
    border: 1px solid #21262D;
    border-radius: 6px;
    font-size: 13px;
    font-family: 'Inter', 'SF Pro', 'Segoe UI', 'Noto Sans CJK SC', 'Microsoft YaHei', sans-serif;
}
QTableWidget::item, QTreeWidget::item {
    padding: 6px 8px;
    border-bottom: 1px solid #21262D;
}
QTableWidget::item:hover, QTreeWidget::item:hover {
    background: #161B22;
}
QTableWidget::item:selected, QTreeWidget::item:selected {
    background: #0066CC1A;
    color: #FFFFFF;
}
QHeaderView::section {
    background: #161B22;
    color: #8B949E;
    font-weight: 600;
    font-size: 12px;
    padding: 8px 10px;
    border: none;
    border-bottom: 1px solid #21262D;
    border-right: 1px solid #21262D;
    font-family: 'Inter', 'SF Pro', 'Segoe UI', 'Noto Sans CJK SC', 'Microsoft YaHei', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}
QHeaderView::section:last {
    border-right: none;
}
QHeaderView::section:first {
    border-top-left-radius: 6px;
}
QHeaderView::section:last {
    border-top-right-radius: 6px;
}
QHeaderView::section:hover {
    background: #1C2128;
}

/* ── Tree Navigation ─────────────────────────────────────── */
QTreeWidget {
    background: #161B22;
    border: none;
    border-right: 1px solid #21262D;
    padding: 8px 0;
    outline: none;
}
/* Category header items (top-level, no parent) */
QTreeWidget::item:first-child,
QTreeWidget > QTreeWidgetItem {
    color: #484F58;
    font-size: 11px;
    font-weight: 600;
    font-family: 'Inter', 'SF Pro', 'Segoe UI', sans-serif;
    padding: 12px 18px 4px;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    min-height: 20px;
    border: none;
}
/* Normal nav items */
QTreeWidget::item {
    color: #8B949E;
    padding: 6px 18px;
    font-size: 13px;
    font-family: 'Inter', 'SF Pro', 'Segoe UI', 'Noto Sans CJK SC', 'Microsoft YaHei', sans-serif;
    min-height: 28px;
    border-radius: 0;
    border: none;
}
QTreeWidget::item:hover {
    background: #1C2128;
    color: #E6EDF3;
}
QTreeWidget::item:selected {
    background: #0066CC1A;
    color: #FFFFFF;
    border-left: 2px solid #0066CC;
    padding-left: 16px;
}

/* ── Menu Bar ─────────────────────────────────────────────── */
QMenuBar {
    background: #0F1419;
    color: #E6EDF3;
    font-size: 13px;
    font-family: 'Inter', 'SF Pro', 'Segoe UI', 'Noto Sans CJK SC', 'Microsoft YaHei', sans-serif;
    border-bottom: 1px solid #21262D;
    padding: 3px 0;
}
QMenuBar::item {
    padding: 5px 12px;
    border-radius: 4px;
}
QMenuBar::item:selected {
    background: #1C2128;
    color: #FFFFFF;
}
QMenuBar::item:pressed {
    background: #1C2128;
}

/* ── Popup Menu ───────────────────────────────────────────── */
QMenu {
    background: #161B22;
    border: 1px solid #21262D;
    border-radius: 6px;
    padding: 4px;
    font-size: 13px;
    font-family: 'Inter', 'SF Pro', 'Segoe UI', 'Noto Sans CJK SC', 'Microsoft YaHei', sans-serif;
}
QMenu::item {
    padding: 6px 14px;
    border-radius: 4px;
    color: #E6EDF3;
}
QMenu::item:selected {
    background: #1C2128;
    color: #FFFFFF;
}
QMenu::item:disabled {
    color: #6E7681;
}
QMenu::separator {
    height: 1px;
    background: #21262D;
    margin: 3px 6px;
}
QMenu::icon {
    margin-left: 4px;
}

/* ── Status Bar ───────────────────────────────────────────── */
QStatusBar {
    background: #0F1419;
    color: #8B949E;
    font-size: 12px;
    font-family: 'Inter', 'SF Pro', 'Segoe UI', sans-serif;
    border-top: 1px solid #21262D;
    padding: 4px 12px;
}
QStatusBar::item {
    border: none;
}

/* ── GroupBox ─────────────────────────────────────────────── */
QGroupBox {
    font-weight: 600;
    font-size: 12px;
    font-family: 'Inter', 'SF Pro', 'Segoe UI', 'Noto Sans CJK SC', 'Microsoft YaHei', sans-serif;
    color: #8B949E;
    border: 1px solid #21262D;
    border-radius: 6px;
    margin-top: 10px;
    padding: 8px 12px 8px 12px;
    background: transparent;
}
QGroupBox::title {
    color: #0066CC;
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 6px;
    font-weight: 600;
    font-size: 11.5px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

/* ── Tab Widget ───────────────────────────────────────────── */
QTabWidget::pane {
    background: #0A0E14;
    border: 1px solid #21262D;
    border-radius: 6px;
    padding: 12px;
}
QTabBar::tab {
    background: #161B22;
    color: #8B949E;
    border: 1px solid #21262D;
    border-bottom: none;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    padding: 6px 16px;
    font-size: 13px;
    font-weight: 500;
    margin-right: 2px;
}
QTabBar::tab:selected {
    background: #0A0E14;
    color: #E6EDF3;
    border-color: #21262D;
    border-bottom: 1px solid #0A0E14;
}
QTabBar::tab:hover:!selected {
    background: #1C2128;
    color: #E6EDF3;
}

/* ── Scroll Bars ──────────────────────────────────────────── */
QScrollBar:vertical {
    background: #0A0E14;
    width: 6px;
    border-radius: 3px;
    margin: 2px;
}
QScrollBar::handle:vertical {
    background: #21262D;
    border-radius: 3px;
    min-height: 30px;
}
QScrollBar::handle:vertical:hover { background: #30363D; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}
QScrollBar:horizontal {
    background: #0A0E14;
    height: 6px;
    border-radius: 3px;
    margin: 2px;
}
QScrollBar::handle:horizontal {
    background: #21262D;
    border-radius: 3px;
    min-width: 30px;
}
QScrollBar::handle:horizontal:hover { background: #30363D; }
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0px;
}
QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
    background: none;
}

/* ── Tool Tip ─────────────────────────────────────────────── */
QToolTip {
    background: #21262D;
    color: #E6EDF3;
    border: 1px solid #30363D;
    border-radius: 4px;
    padding: 5px 8px;
    font-size: 12px;
}

/* ── Message Box ──────────────────────────────────────────── */
QMessageBox {
    background: #161B22;
}
QMessageBox QLabel {
    color: #E6EDF3;
    font-size: 13px;
}
QMessageBox QPushButton {
    min-width: 80px;
    padding: 6px 16px;
}

/* ── CheckBox ─────────────────────────────────────────────── */
QCheckBox {
    color: #8B949E;
    font-size: 13px;
    font-family: 'Inter', 'SF Pro', 'Segoe UI', 'Noto Sans CJK SC', 'Microsoft YaHei', sans-serif;
    spacing: 8px;
}
QCheckBox:hover { color: #E6EDF3; }
QCheckBox::indicator {
    width: 15px;
    height: 15px;
    border-radius: 3px;
    border: 1.5px solid #30363D;
    background: #0F1419;
}
QCheckBox::indicator:checked {
    background: #0066CC;
    border-color: #0066CC;
}
QCheckBox::indicator:hover {
    border-color: #0066CC;
}
QCheckBox::indicator:disabled {
    background: #161B22;
    border-color: #21262D;
}

/* ── Radio Button ─────────────────────────────────────────── */
QRadioButton {
    color: #8B949E;
    font-size: 13px;
    font-family: 'Inter', 'SF Pro', 'Segoe UI', 'Noto Sans CJK SC', 'Microsoft YaHei', sans-serif;
    spacing: 8px;
}
QRadioButton:hover { color: #E6EDF3; }
QRadioButton::indicator {
    width: 15px;
    height: 15px;
    border-radius: 7px;
    border: 1.5px solid #30363D;
    background: #0F1419;
}
QRadioButton::indicator:checked {
    background: #0066CC;
    border-color: #0066CC;
}
QRadioButton::indicator:hover { border-color: #0066CC; }

/* ── SpinBox ─────────────────────────────────────────────── */
QSpinBox, QDoubleSpinBox {
    background: #0F1419;
    color: #E6EDF3;
    border: 1px solid #21262D;
    border-radius: 4px;
    padding: 7px 10px;
    font-size: 13px;
}
QSpinBox:focus, QDoubleSpinBox:focus { border-color: #0066CC; }
QSpinBox::up-button, QDoubleSpinBox::up-button {
    border: none;
    background: transparent;
    width: 16px;
}
QSpinBox::down-button, QDoubleSpinBox::down-button {
    border: none;
    background: transparent;
    width: 16px;
}
QSpinBox::up-arrow, QDoubleSpinBox::up-arrow {
    width: 8px; height: 8px;
    border-right: 2px solid #8B949E;
    border-top: 2px solid #8B949E;
}
QSpinBox::down-arrow, QDoubleSpinBox::down-arrow {
    width: 8px; height: 8px;
    border-right: 2px solid #8B949E;
    border-bottom: 2px solid #8B949E;
}

/* ── Dialog Button Box ────────────────────────────────────── */
QDialogButtonBox QPushButton {
    min-width: 80px;
    padding: 6px 16px;
}
QDialogButtonBox > QPushButton:clicked {
    background: #0066CC;
    color: #FFFFFF;
}

/* ── Splitter ─────────────────────────────────────────────── */
QSplitter::handle {
    background: #21262D;
}
QSplitter::handle:hover {
    background: #30363D;
}

/* ── Frame ────────────────────────────────────────────────── */
QFrame[frameShape="4"], QFrame[frameShape="5"] {
    /* Vertical/Horizontal Line */
    background: #21262D;
    border: none;
}

/* ── List Widget ──────────────────────────────────────────── */
QListWidget {
    background: #0A0E14;
    color: #E6EDF3;
    border: 1px solid #21262D;
    border-radius: 6px;
    font-size: 13px;
}
QListWidget::item {
    padding: 6px 10px;
    border-bottom: 1px solid #21262D;
}
QListWidget::item:hover { background: #161B22; }
QListWidget::item:selected {
    background: #0066CC1A;
    color: #FFFFFF;
}

/* ── Calendar (QDatePicker etc.) ─────────────────────────── */
QCalendarWidget QWidget {
    background: #161B22;
    color: #E6EDF3;
}
QCalendarWidget QToolButton {
    background: transparent;
    color: #E6EDF3;
    border: none;
}
QCalendarWidget QMenu {
    background: #21262D;
}
QCalendarWidget QSpinBox {
    background: #0F1419;
    color: #E6EDF3;
    border: 1px solid #21262D;
}
QCalendarWidget QAbstractItemView {
    background: #161B22;
    color: #E6EDF3;
    selection-background-color: #0066CC;
    border: 1px solid #21262D;
}

/* ── Progress Bar ─────────────────────────────────────────── */
QProgressBar {
    background: #161B22;
    color: #E6EDF3;
    border: 1px solid #21262D;
    border-radius: 4px;
    text-align: center;
    font-size: 12px;
}
QProgressBar::chunk {
    background: #0066CC;
    border-radius: 3px;
}

/* ── Slider ───────────────────────────────────────────────── */
QSlider::groove:horizontal {
    border: 1px solid #21262D;
    height: 4px;
    background: #21262D;
    border-radius: 2px;
}
QSlider::handle:horizontal {
    background: #0066CC;
    border: none;
    width: 14px;
    height: 14px;
    margin: -5px 0;
    border-radius: 7px;
}
QSlider::handle:horizontal:hover { background: #0052A3; }
QSlider::sub-page:horizontal {
    background: #0066CC;
    border-radius: 2px;
}

/* ── Status Label Variants ───────────────────────────────── */
/* 使用方法：在代码中设置 setObjectName("statusSuccess") 等 */
QLabel#statusSuccess {
    color: #22C55E;
    background: #22C55E1A;
    border: 1px solid #22C55E33;
    border-radius: 4px;
    padding: 2px 8px;
    font-size: 12px;
    font-weight: 500;
}
QLabel#statusDanger {
    color: #E53E3E;
    background: #E53E3E1A;
    border: 1px solid #E53E3E33;
    border-radius: 4px;
    padding: 2px 8px;
    font-size: 12px;
    font-weight: 500;
}
QLabel#statusWarning {
    color: #F59E0B;
    background: #F59E0B1A;
    border: 1px solid #F59E0B33;
    border-radius: 4px;
    padding: 2px 8px;
    font-size: 12px;
    font-weight: 500;
}
QLabel#statusInfo {
    color: #3B82F6;
    background: #3B82F61A;
    border: 1px solid #3B82F633;
    border-radius: 4px;
    padding: 2px 8px;
    font-size: 12px;
    font-weight: 500;
}
QLabel#statusPurple {
    color: #8B5CF6;
    background: #8B5CF61A;
    border: 1px solid #8B5CF633;
    border-radius: 4px;
    padding: 2px 8px;
    font-size: 12px;
    font-weight: 500;
}
QLabel#statusNeutral {
    color: #8B949E;
    background: #8B949E1A;
    border: 1px solid #8B949E33;
    border-radius: 4px;
    padding: 2px 8px;
    font-size: 12px;
    font-weight: 500;
}

/* ── Card Container ──────────────────────────────────────── */
#card {
    background: #0F1419;
    border: 1px solid #21262D;
    border-radius: 6px;
    padding: 16px;
}

/* ── Accent Bar (dialog top strip) ───────────────────────── */
#accentBar {
    background: #0066CC;
    border-radius: 12px 12px 0 0;
}

/* ── Error / Validation ───────────────────────────────────── */
QLabel#errLabel, QLabel#errorLabel {
    color: #E53E3E;
    font-size: 12px;
    font-weight: 500;
    min-height: 18px;
}

/* ── Section Label (uppercase) ────────────────────────────── */
QLabel#sectionLabel {
    color: #0066CC;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.8px;
}

/* ── Page Title ───────────────────────────────────────────── */
QLabel#pageTitle {
    color: #FFFFFF;
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.3px;
}

/* ── Monospace (IDs, codes) ───────────────────────────────── */
QLabel#monoLabel, .mono {
    font-family: 'JetBrains Mono', 'SF Mono', 'Consolas', monospace;
    font-size: 12px;
    color: #8B949E;
}

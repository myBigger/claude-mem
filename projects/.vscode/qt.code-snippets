{
    "Qt Header File": {
        "prefix": ["qth", "qt header"],
        "body": [
            "/**",
            " * @file ${1:filename}.h",
            " * @brief ${2:brief description}",
            " * @author PrisonSIS Team",
            " * @date ${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}",
            " */",
            "",
            "#ifndef ${1:$(echo $1 | tr '[:lower:]' '[:upper:]')}_H",
            "#define ${1:$(echo $1 | tr '[:lower:]' '[:upper:]')}_H",
            "",
            "#include <QObject>",
            "#include <QWidget>",
            "#include <QDebug>",
            "",
            "// Qt6 头文件 (按模块分组)",
            "// #include <QtCore>",
            "// #include <QtGui>",
            "// #include <QtWidgets>",
            "",
            "class ${1:ClassName} : public QObject",
            "{",
            "    Q_OBJECT",
            "",
            "public:",
            "    /** @brief 构造函数 */",
            "    explicit ${1:ClassName}(QObject *parent = nullptr);",
            "    /** @brief 析构函数 */",
            "    ~${1:ClassName}();",
            "",
            "    /** @brief 初始化 */",
            "    void initialize();",
            "",
            "    /** @brief 获取实例 */",
            "    static ${1:ClassName}& instance();",
            "",
            "signals:",
            "    /** @brief 信号: 初始化完成 */",
            "    void initialized();",
            "",
            "public slots:",
            "    /** @brief 槽: 重置 */",
            "    void reset();",
            "",
            "private:",
            "    /** @brief 私有构造函数 */",
            "    ${1:ClassName}(const ${1:ClassName}&) = delete;",
            "    /** @brief 禁止赋值 */",
            "    ${1:ClassName}& operator=(const ${1:ClassName}&) = delete;",
            "",
            "private:",
            "    bool m_initialized = false;",
            "};",
            "",
            "#endif // ${1:$(echo $1 | tr '[:lower:]' '[:upper:]')}_H"
        ],
        "description": "Qt Class Header Template for PrisonSIS"
    },
    "Qt Widget Header": {
        "prefix": ["qwh", "qt widget header"],
        "body": [
            "/**",
            " * @file ${1:filename}.h",
            " * @brief ${2:brief description}",
            " * @author PrisonSIS Team",
            " * @date ${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}",
            " */",
            "",
            "#ifndef ${1:$(echo $1 | tr '[:lower:]' '[:upper:]')}_H",
            "#define ${1:$(echo $1 | tr '[:lower:]' '[:upper:]')}_H",
            "",

{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake: configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                "${workspaceFolder}",
                "-B",
                "${workspaceFolder}/build",
                "-G",
                "Unix Makefiles",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
                "-DQt6_DIR=/usr/lib/x86_64-linux-gnu/cmake/Qt6"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "配置 CMake 项目"
        },
        {
            "label": "cmake: build debug",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--config",
                "Debug",
                "--parallel"
            ],
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "dependsOn": [
                "cmake: configure"
            ],
            "detail": "构建项目 (Debug)"
        },
        {
            "label": "cmake: build release",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--config",
                "Release",
                "--parallel"
            ],
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "dependsOn": [
                "cmake: configure"
            ],
            "detail": "构建项目 (Release)"
        },
        {
            "label": "cmake: clean",
            "type": "shell",
            "command": "rm",
            "args": [
                "-rf",
                "${workspaceFolder}/build"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "清理构建目录"
        },
        {
            "label": "cmake: configure Windows",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                "${workspaceFolder}",
                "-B",
                "${workspaceFolder}/build-windows",
                "-G",
                "Visual Studio 17 2022",
                "-A",
                "x64",
                "-DCMAKE_BUILD_TYPE=Release",
                "-DQt6_DIR=C:/Qt/6.7.0/msvc2022_64/lib/cmake/Qt6",
                "-DOPENSSL_ROOT=C:/Program Files/OpenSSL-Win64"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "配置 CMake 项目 (Windows)"
        },
        {
            "label": "cmake: build Windows",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build-windows",
                "--config",
                "Release",
                "--parallel"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "dependsOn": [
                "cmake: configure Windows"
            ],
            "detail": "构建项目 (Windows)"
        },
        {
            "label": "make: build",
            "type": "shell",
            "command": "make",
            "args": [
                "-j$(nproc)",
                "-C",
                "${workspaceFolder}/build"
            ],
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "使用 Make 构建"
        },
        {
            "label": "clang-tidy: check",
            "type": "shell",
            "command": "clang-tidy",
            "args": [
                "-p=${workspaceFolder}/build",
                "${workspaceFolder}/src/**/*.cpp"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "detail": "运行 clang-tidy 代码检查"
        },
        {
            "label": "cmake: install",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--install",
                "${workspaceFolder}/build",
                "--prefix",
                "${workspaceFolder}/install"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "none",
                "isDefault": false
            },
            "detail": "安装项目"
        },
        {
            "label": "docker: build",
            "type": "shell",
            "command": "docker",
            "args": [
                "build",
                "-t",
                "prisonsis:latest",
                "-f",
                "${workspaceFolder}/Dockerfile",
                "${workspaceFolder}"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "none",
                "isDefault": false
            },
            "detail": "构建 Docker 镜像"
        }
    ]
}
